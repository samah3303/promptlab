# ─── PromptLab Environment Variables ───

# Required: DeepSeek API Key (get at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ─── Neon PostgreSQL (Required) ───
# Get your connection details from https://console.neon.tech
NEON_HOST=ep-example-123456.us-east-2.aws.neon.tech
NEON_DATABASE=promptlab
NEON_USER=neondb_owner
NEON_PASSWORD=your-neon-password-here

# Alternative: full connection URL (overrides individual fields)
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ─── Server ───
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=*

# ─── Ollama (Optional — local LLM) ───
# Set to false to disable Ollama integration
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
